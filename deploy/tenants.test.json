      "logs_dir": "./logs/taishan",
      "roles": ["api", "worker"]
    },
    {
      "_comment": "第二租户模板 — 取消注释并创建 secrets/tenant-b.env 即生效",
      "id": "tenant-b",
      "name": "Tenant B (test)",
      "api_port": 8102,
      "env_file": "secrets/tenant-b.env",
      "data_dir": "./data/tenant-b",
      "logs_dir": "./logs/tenant-b",
      "roles": ["api", "stream", "worker"]
    }
  ]
}
