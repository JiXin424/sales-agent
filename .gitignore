# Secrets — 真实租户凭证绝不提交
.env
*.env
# Ignore everything inside secrets/, but keep the committed template.
# NOTE: must use `secrets/*` (not `secrets/`); a fully-ignored directory
# cannot have individual files re-included by `!` later.
secrets/*
!secrets/example.env
!secrets/neo4j.env.example

# 本地 Claude Code 配置切换工具（含 API token，绝不提交）
changmodel.sh

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test
.pytest_cache/
htmlcov/
.coverage

# Data
data/sales-agent/tenants/*/documents/*.pdf
data/sales-agent/tenants/*/documents/*.docx
# 本体入库上传的源文件副本(运行时产物,知识正文已入 Neo4j/DB,不进 git)
data/agents/

# 仓库根游离的 ontology zip 副本(误提交的产物包;正式 toolkit.zip 不匹配此模式)
*_ontology_*.zip

# Logs
logs/
*.log

# Eval results (generated)
eval/results/*
!eval/results/.gitkeep

# OS
.DS_Store
Thumbs.db
# Generated deployment files
docker-compose.generated.yml
traefik/generated-dynamic.yml
deploy/tenants.json

# Frontend 构建产物(console 自带 dist/node_modules)
console/node_modules/
console/dist/
console/tsconfig.tsbuildinfo

# 仓库根游离的大文件副本(正式副本在 src/.../static/ 下,会进镜像)
coach_mode.png
cocah.mp4
cocah.html
# src/static/ 下的正式副本是运行时必需资源(register 按钮图标、教练视频页),
# 必须入仓——裸名会递归排除它们,导致 CI 镜像缺失→register/教练页 500。用 ! 反例放行(同 secrets/example.env)。
!src/sales_agent/integrations/dingtalk/static/coach_mode.png
!src/sales_agent/integrations/dingtalk/static/cocah.html

# Traefik 运行时凭证/状态(绝不提交)
traefik/acme.json
traefik/certs/

# 游离的 pip resolver 垃圾
=0.20.0

