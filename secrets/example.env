# ============================================================
# ⚠️  EXAMPLE / TEMPLATE — DO NOT FILL WITH REAL SECRETS
# ============================================================
# This file is the ONLY file under secrets/ that is tracked by git.
# scripts/deploy-release.sh deliberately SKIPS it (reserved name
# "example.env"), so it will never appear in the tenant selection
# menu and can never be deployed.
#
# How to add a real tenant:
#   cp secrets/example.env secrets/<tenant-id>.env
#   chmod 600 secrets/<tenant-id>.env
#   # then edit values and replace every <...> placeholder below
#
# (Real tenant env files are git-ignored; this template is not.)
# ============================================================

# --- Deployment mode ---
DEPLOYMENT_MODE=dedicated
TENANT_ID=<your-tenant-id>
TENANT_NAME=<Your Tenant Display Name>

# --- Model provider ---
MODEL_PROVIDER=openai_compatible
MODEL_API_KEY=<sk-...>
MODEL_BASE_URL=https://api.example.com/v1
MODEL_CHAT_MODEL=qwen-plus
MODEL_EMBEDDING_MODEL=text-embedding-v3

# Optional independent embedding provider.
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# --- Tenant storage ---
VECTOR_COLLECTION=<tenant-id>
DATA_DIR=/data/<tenant-id>
LOG_DIR=/logs/<tenant-id>

# --- DingTalk single chat ---
DINGTALK_ENABLED=false
DINGTALK_MESSAGE_MODE=stream
DINGTALK_CORP_ID=<ding-corp-id>
DINGTALK_APP_KEY=<ding-app-key>
DINGTALK_APP_SECRET=<ding-app-secret>
DINGTALK_ROBOT_CODE=<ding-robot-code>

# Stream card rendering is optional. Leave disabled until the template id is ready.
DINGTALK_STREAMING_ENABLED=false
DINGTALK_CARD_TEMPLATE_ID=
DINGTALK_STREAM_UPDATE_INTERVAL_MS=300
DINGTALK_STREAM_MIN_CHUNK_CHARS=30

# --- DingTalk quick entry registration during deployment ---
# true: scripts/deploy-release.sh calls this instance API to register DingTalk shortcuts.
DINGTALK_REGISTER_QUICK_ENTRY=true
DINGTALK_QUICK_ENTRY_CLEAR_FIRST=true
DINGTALK_QUICK_ENTRY_ENTRIES=coach,small_win_appreciation,sales_block_breakthrough
DINGTALK_QUICK_ENTRY_NAME=教练模式

# HTTP callback mode only.
DINGTALK_ENCRYPT_TOKEN=
DINGTALK_AES_KEY=
DINGTALK_PUBLIC_URL=https://<tenant-id>-agent.example.com

# --- Knowledge engine / Ontology ---
# Knowledge engine: legacy_rag | ontology_neo4j
KNOWLEDGE_ENGINE=ontology_neo4j
ONTOLOGY_VECTOR_FALLBACK=conservative
# Neo4j 连接信息（URI/USER/PASSWORD/DATABASE）由生成器统一注入 compose，
# 共享密码来自 secrets/neo4j.env（${NEO4J_PASSWORD} 插值），不在此处重复。
