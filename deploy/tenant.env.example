# ============================================================
# Sales Agent — 租户环境变量模板（唯一权威真源）
# ============================================================
# 本文件是租户 env 的唯一权威模板。以下两个文件都是指向它的软链，
# 请勿单独维护，改这里即可（改动会随 CI/CD 自动发布到无源码目标机）：
#   - secrets/example.env  ->  ../deploy/tenant.env.example
#   - .env.example         ->  deploy/tenant.env.example
#
# 使用方式（新增租户）：
#   cp secrets/example.env secrets/<tenant-id>.env
#   chmod 600 secrets/<tenant-id>.env
#   # 然后填入真实值，替换所有 <...> 占位符
#
# 使用方式（本机单进程 dev）：
#   cp .env.example .env
#   chmod 600 .env
#
# ⚠️  本模板不含任何真实密钥，所有敏感值均为占位符。真实租户 env 文件
#     (secrets/<tenant>.env) 被 git 忽略；仅本模板纳入 git 追踪。
#
# 多租户 CI/CD 部署时，DATABASE_URL 与 NEO4J_* 由生成器
# (scripts/render-multitenant-deploy.py) 注入 compose，无源码机无需在此填写；
# 仅本机单进程 dev 需取消注释并填本地值。
# ============================================================

# --- 部署模式 ---
DEPLOYMENT_MODE=dedicated
TENANT_ID=<your-tenant-id>
TENANT_NAME=<Your Tenant Display Name>

# --- Chat 模型 ---
MODEL_PROVIDER=openai_compatible
MODEL_API_KEY=<sk-...>
MODEL_BASE_URL=https://api.example.com/v1
MODEL_CHAT_MODEL=deepseek-chat

# --- Embedding 模型（可选独立 provider，留空则复用上面的 provider）---
MODEL_EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=<embedding-sk-...>
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 数据库 ---
# CI/CD 多租户部署：由生成器注入 compose，无需在此填。
# 本机 dev：取消注释并填本地连接串。
# DATABASE_URL=postgresql+asyncpg://sales_agent:sales_agent_dev@localhost:5432/sales_agent

# --- 存储 ---
VECTOR_COLLECTION=<tenant-id>
DATA_DIR=/data/<tenant-id>
LOG_DIR=/logs/<tenant-id>

# --- 钉钉集成（单聊）---
# 设置 DINGTALK_ENABLED=true 开启钉钉接入。
DINGTALK_ENABLED=false
# 消息模式：stream（默认，常驻 WebSocket 连接）或 http（HTTP 回调）。
DINGTALK_MESSAGE_MODE=stream
DINGTALK_CORP_ID=<ding-corp-id>
DINGTALK_APP_KEY=<ding-app-key>
DINGTALK_APP_SECRET=<ding-app-secret>
DINGTALK_ROBOT_CODE=<ding-robot-code>
# 可选：部分企业接口需要 agent_id。
DINGTALK_AGENT_ID=

# --- 钉钉流式卡片（可选）---
# 需先在钉钉后台配置卡片模板；模板 id 就绪前保持 false。
DINGTALK_STREAMING_ENABLED=false
DINGTALK_CARD_TEMPLATE_ID=
DINGTALK_STREAM_UPDATE_INTERVAL_MS=300
DINGTALK_STREAM_MIN_CHUNK_CHARS=30

# --- 钉钉 HTTP 回调（仅 http 模式需要；stream 模式留空即可）---
DINGTALK_ENCRYPT_TOKEN=
DINGTALK_AES_KEY=

# --- 钉钉多媒体理解（图片 + 语音）---
# 设置 DINGTALK_MEDIA_ENABLED=true 开启图片/语音消息理解。
DINGTALK_MEDIA_ENABLED=false
DINGTALK_MEDIA_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DINGTALK_MEDIA_API_KEY=<media-sk-...>
DINGTALK_VISION_MODEL=qwen-vl-max
DINGTALK_AUDIO_MODEL=qwen-audio-turbo
# 媒体下载超时（秒），默认即可。
# DINGTALK_MEDIA_DOWNLOAD_TIMEOUT_SECONDS=30

# --- 钉钉快捷入口注册（部署时）---
# true: scripts/deploy-release.sh 调用实例 API 注册钉钉快捷入口。
DINGTALK_REGISTER_QUICK_ENTRY=true
DINGTALK_QUICK_ENTRY_CLEAR_FIRST=true
DINGTALK_QUICK_ENTRY_ENTRIES=coach,small_win_appreciation,sales_block_breakthrough
DINGTALK_QUICK_ENTRY_NAME=教练模式
# 免登录/快捷入口的公开 URL。若分配了子域名，使用 https://{tenant}.aijiaolian.com.cn
# （需配合 tenants.json 的 domain 字段 + 钉钉 OAuth2 redirect_uri 白名单）。
DINGTALK_PUBLIC_URL=https://<tenant-id>-agent.example.com

# --- 知识引擎 / 本体 ---
# 知识引擎：legacy_rag | ontology_neo4j
KNOWLEDGE_ENGINE=ontology_neo4j
# 混合检索（图 + 向量）；ontology_neo4j 下建议开启。
HYBRID_RETRIEVAL=true
# 本体命中不足时的向量回退策略：conservative | aggressive
ONTOLOGY_VECTOR_FALLBACK=conservative

# --- Neo4j 本体知识引擎连接 ---
# CI/CD 多租户部署：由生成器从 secrets/neo4j.env 注入 compose（${NEO4J_PASSWORD} 插值），
# 无源码机无需在此填写。仅本机 dev 需取消注释并填本地值。
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=<neo4j-password>
# NEO4J_DATABASE=neo4j
# NEO4J_VISUAL_URL=http://localhost:7474

# --- 联网搜索兜底（Bocha API）---
# 本体/向量都没命中时兜底联网搜索；留空则关闭。
BOCHA_API_KEY=<bocha-api-key>
# 联网搜索返回条数，默认即可。
# BOCHA_TOP_N=5

# --- 统一引导流程 ---
# Unified online guided flows；设 false 可立即回滚到纯 Chat 路由。
GUIDED_FLOWS_ENABLED=true

# --- 有界意图路由（话题管理、上下文解析、证据路由）---
# 设 TOPIC_ROUTING_ENABLED=true 开启话题管理 + 上下文解析 + 证据路由。
# 关闭（默认）时所有消息直接进 Chat 管线，不做话题跟踪/证据路由。
TOPIC_ROUTING_ENABLED=false

# --- 场景教练（预设销售场景问答）---
# 设 SCENARIO_COACH_ENABLED=true：用户问题命中预设销售场景（confidence≥阈值）
# → 返回预设答案 + 手册来源，跳过 AI 生成；未命中 → 原样走正常 AI，行为零变化。
SCENARIO_COACH_ENABLED=false
# 命中置信度阈值（0-1），低于此值视为未命中、走正常 AI 回答。
SCENARIO_COACH_CONFIDENCE_THRESHOLD=0.8

# --- 高级 / 内部调优（一般无需改，默认即可）---
# LLM 路径路由器（关闭则纯规则路由）。
# PATH_ROUTER_ENABLE_LLM_ROUTER=false
# LLM 高风险内容复核。
# RISK_ENABLE_LLM_RISK_CHECK=false
