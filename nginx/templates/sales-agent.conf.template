# ============================================================
# Sales Agent — 站点配置
# ============================================================
# 域名：qiyelongxia.com.cn
# 后端：Docker 内部网络 → taishan-agent:8000 或 taishan-api:8000
#
# 使用 resolver + variable 动态解析后端服务名，
# 避免不同 profile 下 nginx 启动失败（服务名不存在时不会报错）
# ============================================================

# Docker 内部 DNS 解析器（容器内 /etc/resolv.conf 自动配置）
resolver 127.0.0.11 valid=30s ipv6=off;

# ============================================================
# HTTP (80) — Let's Encrypt ACME 挑战 + HTTPS 重定向
# ============================================================
server {
    listen 80;
    server_name qiyelongxia.com.cn;

    # Let's Encrypt 证书验证路径
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    # 其他所有请求重定向到 HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# ============================================================
# HTTPS (443) — 主站点
# ============================================================
server {
    listen 443 ssl http2;
    server_name qiyelongxia.com.cn;

    # --- SSL 证书（Let's Encrypt）---
    ssl_certificate     /etc/letsencrypt/live/qiyelongxia.com.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/qiyelongxia.com.cn/privkey.pem;

    # --- SSL 参数 ---
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    # HSTS（6 个月）
    add_header Strict-Transport-Security "max-age=15768000; includeSubDomains" always;

    # --- 反向代理到后端 ---
    # BACKEND_SERVICE 由 docker-compose 环境变量注入
    # taishan profile → taishan-agent
    # taishan-split profile → taishan-api
    set $backend_host "${BACKEND_SERVICE}";

    location / {
        proxy_pass http://$backend_host:8000;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket 支持（钉钉 Stream 模式备用）
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";

        # 超时设置
        proxy_connect_timeout 60s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;
    }
}
