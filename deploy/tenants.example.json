{
  "project_name": "sales-agent",
  "image": "sales-agent:latest",
  "postgres_image": "docker.1ms.run/pgvector/pgvector:pg16",
  "database": {
    "name": "sales_agent",
    "user": "sales_agent",
    "password": "sales_agent_dev"
  },
  "neo4j": {
    "enabled": true,
    "image": "registry.internal:5000/neo4j:5",
    "expose_ports": false
  },
  "traefik": {
    "enabled": true,
    "dynamic_output": "/root/code/traefik/dynamic.d/generated-sales-agent.yml",
    "shared_network": "taishan-network"
  },
  "output": {
    "compose_file": "docker-compose.generated.yml"
  },
  "tenants": [
    {
      "id": "acme",
      "name": "ACME Enterprise",
      "domain": "acme-agent.example.com",
      "backend": "",
      "_domain_comment": "子域名。有 domain 时自动生成 Host(domain) 路由。若本机有前端容器则另加 catch-all。",
      "_backend_comment": "可选。远端 API 的 host:port（如 172.25.186.210:8003）。缺省=本机 sales-agent-{id}-api:8000。",
      "api_port": 8101,
      "env_file": "secrets/acme.env",
      "data_dir": "./data/acme",
      "logs_dir": "./logs/acme",
      "roles": ["api", "stream", "worker"]
    },
    {
      "id": "beta",
      "name": "Beta Enterprise",
      "domain": "beta-agent.example.com",
      "api_port": 8102,
      "env_file": "secrets/beta.env",
      "data_dir": "./data/beta",
      "logs_dir": "./logs/beta",
      "roles": ["api", "stream", "worker"]
    }
  ]
}
