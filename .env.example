# ============================================================
# Sales Agent — 租户环境变量模板
# ============================================================
# 使用方式：复制为 .env 并填入实际值
#   cp .env.example .env
#   chmod 600 .env
# ============================================================

# --- 部署模式 ---
DEPLOYMENT_MODE=dedicated
TENANT_ID=taishan
TENANT_NAME=泰山兄弟

# --- 模型配置 ---
MODEL_PROVIDER=openai_compatible
MODEL_API_KEY=
MODEL_BASE_URL=https://api.example.com/v1
MODEL_CHAT_MODEL=qwen-plus
MODEL_EMBEDDING_MODEL=text-embedding-v3

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://sales_agent:sales_agent_dev@localhost:5432/sales_agent

# --- 存储 ---
VECTOR_COLLECTION=
DATA_DIR=
LOG_DIR=

# --- 统一引导流程 ---
# Unified online guided flows; set false for immediate rollback to plain Chat routing.
GUIDED_FLOWS_ENABLED=true

# --- 有界意图路由（话题管理、上下文解析、证据路由）---
# Set TOPIC_ROUTING_ENABLED=true to enable topic management, context resolution,
# and evidence routing. When disabled (default), all messages go directly to
# the Chat pipeline without topic tracking or evidence-based routing.
TOPIC_ROUTING_ENABLED=false

# --- 场景教练（预设销售场景问答）---
# Set SCENARIO_COACH_ENABLED=true to match user questions against preset sales
# scenarios and return a preset answer with a manual citation on high-confidence hits.
SCENARIO_COACH_ENABLED=false
# 命中置信度阈值（0-1），低于此值视为未命中、走正常 AI 回答。
SCENARIO_COACH_CONFIDENCE_THRESHOLD=0.8

# --- 钉钉单聊集成 ---
# 设置 DINGTALK_ENABLED=true 开启钉钉接入
DINGTALK_ENABLED=false
# 消息模式：stream（默认，常驻 WebSocket 连接）或 http（HTTP 回调）
DINGTALK_MESSAGE_MODE=stream
DINGTALK_CORP_ID=你的企业CorpId
DINGTALK_APP_KEY=你的AppKey
DINGTALK_APP_SECRET=你的AppSecret
DINGTALK_ROBOT_CODE=你的RobotCode
# Stream 模式一般不依赖 HTTP 回调 token/aes key
DINGTALK_ENCRYPT_TOKEN=
DINGTALK_AES_KEY=

# --- 知识引擎 / 本体 ---
# Knowledge engine: legacy_rag | ontology_neo4j
KNOWLEDGE_ENGINE=legacy_rag
ONTOLOGY_VECTOR_FALLBACK=conservative

# Neo4j ontology knowledge engine
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_VISUAL_URL=
